{
  "rules": {
    ".read": false,
    ".write": false,

    "presence": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "trackerMappings": {
      "$uuid": {
        ".read":  "auth != null && data.child('uid').val() === auth.uid",
        ".write": "auth != null && (!data.exists() || data.child('uid').val() === auth.uid) && (!newData.exists() || newData.child('uid').val() === auth.uid)"
      }
    },

    "trackerCandidates": {
      "$busId": {
        ".read": "auth != null",
        "$uuid": {
          ".write": "auth != null && root.child('trackerMappings').child($uuid).child('uid').val() === auth.uid && root.child('trackerMappings').child($uuid).child('busId').val() === $busId"
        }
      }
    },

    "approachingStudents": {
      "$busId": {
        ".read": "auth != null",
        "$uuid": {
          ".write": "auth != null && root.child('trackerMappings').child($uuid).child('uid').val() === auth.uid && root.child('trackerMappings').child($uuid).child('busId').val() === $busId"
        }
      }
    },

    "trackerAssignments": {
      "$busId": {
        ".read":  "auth != null",
        "leader": {
          ".write": "auth != null && (!newData.exists() || (root.child('trackerMappings').child(newData.child('uid').val()).child('uid').val() === auth.uid && root.child('trackerMappings').child(newData.child('uid').val()).child('busId').val() === $busId))"
        }
      }
    },

    "busLocations": {
      "$busId": {
        ".read":  "auth != null",
        ".write": false
      }
    },

    "busHealth": {
      "$busId": {
        ".read":  "auth != null",
        ".write": false
      }
    },

    "sessions": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}
