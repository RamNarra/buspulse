rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    // Tier helper: God Mode (tier 2) can read any bus data.
    function isGodMode() {
      return isSignedIn() && request.auth.token.tier == 'god';
    }

    // ── Students ────────────────────────────────────────────────────────────
    // Each student can only read their own document. No direct writes allowed.
    match /students/{studentId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow write: if false;
    }

    // ── Buses ────────────────────────────────────────────────────────────────
    match /buses/{busId} {
      allow read: if isAdmin() || isGodMode() || (isSignedIn() && request.auth.token.assignedBusId == busId);
      allow write: if isAdmin();
    }

    // ── Live Buses ───────────────────────────────────────────────────────────
    match /live_buses/{busId} {
      allow read: if isAdmin() || isGodMode() || (isSignedIn() && request.auth.token.assignedBusId == busId);
      allow write: if false; // Only backend (Firebase Admin SDK) can write here.
    }

    // ── Routes ───────────────────────────────────────────────────────────────
    match /routes/{routeId} {
      allow read: if isAdmin() || isGodMode() || (isSignedIn() && request.auth.token.assignedRouteId == routeId);
      allow write: if isAdmin();
    }

    // ── Stops ────────────────────────────────────────────────────────────────
    match /stops/{stopId} {
      allow read: if isAdmin()
        || isGodMode()
        || (isSignedIn() && resource.data.routeId == request.auth.token.assignedRouteId);
      allow write: if isAdmin();
    }

    // ── Colleges ─────────────────────────────────────────────────────────────
    match /colleges/{collegeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Parent links — sensitive; backend-only ────────────────────────────────
    match /parentLinks/{parentLinkId} {
      allow read:  if isAdmin() || (isSignedIn() && resource.data.parentUid == request.auth.uid);
      allow write: if isAdmin();
    }

    // ── Subscriptions ─────────────────────────────────────────────────────────
    match /subscriptions/{subscriptionId} {
      allow read:  if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow write: if isAdmin();
    }

    // ── Sessions (1-device enforcement) ───────────────────────────────────────
    match /sessions/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // ── Conservative default ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
